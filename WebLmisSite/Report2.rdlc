          <Textbox Name="Textbox7">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>वरील आदेशा प्रमाणे  संगणकीकृत  ७/१२ मध्ये अमंल  घेतला असे. </Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <rd:DefaultName>Textbox7</rd:DefaultName>
            <Top>3.7582in</Top>
            <Left>0.80909in</Left>
            <Height>0.22292in</Height>
            <Width>4.02724in</Width>
            <ZIndex>33</ZIndex>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
              <VerticalAlign>Middle</VerticalAlign>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>1pt</PaddingTop>
              <PaddingBottom>1pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="Textbox9">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>                 ई - फेरफार प्रकल्पांतर्गत डाटा एन्ट्री मॉड्युल वापरून हस्तलिखीत व संगणकीकृत  अधिकार अभिलेख  (गा .न . नं ७/१२) तंतोतंत  जुळविणे बाबत  शासन परिपत्रक क्र . रा . भू . अ . / प्र क्र . १८० /ल -१,दि . ०७/०५/२०१६ मधील निर्देशानुसार  तहसीलदार  </Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=Parameters!tahsildarname.Value</Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>  जिल्हा    </Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!jilha.Value, "DataSet1")</Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>    यांनी दि.  </Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=Parameters!tahsildardate.Value</Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>   रोजी पारित केलेल्या आदेशानुसार  खालील नमुद संगणकीकृत  ७/१२ या  मध्ये दुरुस्ती केले बाबत नोंद केली  आहे .</Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
