          <Textbox Name="Textbox60">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value xml:space="preserve">           </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>शासनाने अधिकार अभिलेखाचे संगणकीकरण करून ई-फेरफार आज्ञावली राज्यामध्ये लागु करण्याचा निर्णय घेतला आहे.  हस्तलिखित अधिकार अभिलेखाची डेटा एंट्री संगणकामध्ये करण्यात आली आहे.तथापी  हस्तलिखित अधिकार अभिलेख व संगणकीकृत  अधिकार अभिलेख तंतोतंत जुळणे आवश्यक आहे.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value xml:space="preserve">           </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>त्यासाठी Data entry Module ची सुविधा देण्यात  आलेली  आहे. मा.जमाबंदी आयुक्त कार्यालयाकडील दिनांक-05/05/2017 रोजीचे पत्रामधील सुचना विचारात घेऊन संगणकीकृत अधिकार अभिलेख 7/12 मुळ हस्तलिखित अधिकार अभिलेखाशी तंतोतंत जुळण्यासाठी संगणकीकृत अधिकार अभिलेखामध्ये सोबतच्या परिशिष्टामध्ये नमुद केल्याप्रमाणे दुरुस्ती करणे आवश्यक असल्याने मी तहसिलदार        </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve">        </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=Parameters!tahsildarname.Value</Value>
                    <Style>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Bold</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value xml:space="preserve">   </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>मला महाराष्ट्र  जमीन महसुल अधिनियम 1966 मधील कलम 155 प्रमाणे प्राप्त अधिकारान्वये सोबतच्या परिशिष्ट ब मधील पृष्ठ क्रमांक 1 ते           या मध्ये नमुद केल्याप्रमाणे संगणकीकृत अधिकार अभिलेखामधील दुरूस्तीस मान्यता देत आहे. या आदेशाने हस्तलिखित अधिकार अभिलेखामधे कोणतीही दूरूस्ती करण्यात येऊ नये.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value />
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Sakal Marathi</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
