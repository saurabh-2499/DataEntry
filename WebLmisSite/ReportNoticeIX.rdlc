        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>त्याअर्थी आता मी,</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontFamily>Sakal Marathi</FontFamily>
                  <FontWeight>Normal</FontWeight>
